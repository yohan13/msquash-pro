# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=4000

# ─── Sécurité ──────────────────────────────────────────────────────────────────
# IMPORTANT: Remplacer par une valeur aléatoire forte en production
# Exemple : openssl rand -hex 32
JWT_SECRET=change-me-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# CORS: mettre l'URL du frontend en production (ex: https://squash.monclub.fr)
CORS_ORIGIN=*

# ─── Compte admin initial ──────────────────────────────────────────────────────
ADMIN_SEED_EMAIL=admin@club.local
ADMIN_SEED_PASSWORD=admin1234
ADMIN_SEED_NAME=Club Admin

# ─── Configuration du club ─────────────────────────────────────────────────────
CLUB_NAME=M Squash
DAY_START=08:00
DAY_END=22:00
SLOT_MINUTES=45
COURTS=12

# ─── Règles de réservation ─────────────────────────────────────────────────────
MAX_FUTURE_BOOKINGS=2
MAX_DAYS_AHEAD=14
UNIQUE_PER_TIMESLOT=true
